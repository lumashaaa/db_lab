<clickhouse>
    <listen_host>0.0.0.0</listen_host>
    <listen_try>1</listen_try>

    <zookeeper>
        <node><host>s1r1</host><port>9181</port></node>
        <node><host>s1r2</host><port>9181</port></node>
        <node><host>s2r1</host><port>9181</port></node>
    </zookeeper>

    <remote_servers>
        <cluster_2x2>
            <shard>
                <replica><host>s1r1</host><port>9000</port></replica>
                <replica><host>s1r2</host><port>9000</port></replica>
            </shard>
            <shard>
                <replica><host>s2r1</host><port>9000</port></replica>
                <replica><host>s2r2</host><port>9000</port></replica>
            </shard>
        </cluster_2x2>
    </remote_servers>
</clickhouse>
